{
  "name": "WealthWise-App",
  "productName": "WealthWise",
  "description": "Personal finance tracker",
  "author": "Youssef",
  "repository": "https://github.com/Yemam11/budgeting_app",
  "private": true,
  "version": "1.1.5",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n API,UI -c cyan,green \"node server.js\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:all": "npm run build && electron-builder --mac --win"
  },
  "build": {
    "appId": "com.youssef.wealthwise",
    "productName": "WealthWise",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "server.js",
      "electron/**",
      "node_modules/**",
      "package.json",
      "!src/**",
      "!public/**",
      "!release/**",
      "!**/*.ts",
      "!vite.config.*",
      "!tsconfig.*",
      "!tailwind.config.*",
      "!postcss.config.*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "icon": "public/WealthWise Icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "public/wealthwise-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "nanoid": "^5.0.7",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
